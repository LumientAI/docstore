# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# API keys for the extractor, validator, differ, and orchestrator.
# Anthropic is the default provider.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Get one at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Get one at https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# Get one at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=...

# Optional: where the JSON cache lives. Defaults to .docstore in the current directory.
# DOCSTORE_DIR=.docstore

# Optional: provider and model used by every subagent.
# DOCSTORE_PROVIDER=anthropic
# DOCSTORE_MODEL=claude-haiku-4-5-20251001

# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required: Anthropic API key for the extractor, validator, differ, and orchestrator.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: where the JSON cache lives. Defaults to .docstore in the current directory.
# DOCSTORE_DIR=.docstore

# Optional: model used by every subagent. Defaults to claude-haiku-4-5-20251001.
# DOCSTORE_MODEL=claude-haiku-4-5-20251001
